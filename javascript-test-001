let n = 5;
let result = "";


for (let i = 1; i <= n; i++) {
    let row = "";

    
    for (let j = 1; j <= n - i; j++) {
        row += " ";
    }

    if (i === 1) {
        row += "*";
    } else if (i === 2) {
        row += "* *";
    } else {
        row += "*";

        // middle spaces based on your logic
        let spaces = 2 * (i - 2) + 1;
        for (let j = 1; j <= spaces; j++) {
            row += " ";
        }

        row += "*";
    }

    result += row + "\n";
}

for (let i = n - 1; i >= 1; i--) {
    let row = "";

   
    for (let j = 1; j <= n - i; j++) {
        row += " ";
    }

    if (i === 1) {
        row += "*";
    } else if (i === 2) {
        row += "* *";
    } else {
        row += "*";

        let spaces = 2 * (i - 2) + 1;
        for (let j = 1; j <= spaces; j++) {
            row += " ";
        }

        row += "*";
    }

    result += row;
    if (i !== 1) result += "\n"; // avoid extra newline at end
}


console.log(result);
